rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Bieżąca kopia każdego urządzenia — konto techniczne może czytać i nadpisywać.
    match /signoff/{doc}        { allow read, write: if request.auth != null; }
    match /signoff_chunks/{doc} { allow read, write: if request.auth != null; }

    // NIEZMIENIALNA HISTORIA (A+B): można tylko TWORZYĆ nowe migawki i je CZYTAĆ.
    // Nadpisanie i skasowanie są zabronione — backupu nie da się wymazać ani zepsuć.
    match /signoff_history/{doc} {
      allow read, create: if request.auth != null;
      allow update, delete: if false;
    }
    match /signoff_history_chunks/{doc} {
      allow read, create: if request.auth != null;
      allow update, delete: if false;
    }

    // WSPÓLNY REJESTR LOGOWAŃ (zaszyfrowany E2E) — każde urządzenie tylko DOPISUJE i CZYTA.
    // Nadpisanie/skasowanie zabronione — logu nie da się zmienić ani wyczyścić zdalnie.
    match /signoff_logins/{doc} {
      allow read, create: if request.auth != null;
      allow update, delete: if false;
    }

    // Wszystko inne — zabronione.
    match /{document=**} { allow read, write: if false; }
  }
}
